{% comment %}
  House of Clarence — Header
  Sticky, slim, paper surface with a hairline that deepens on scroll.
  Left: logo. Centre/left: room-led nav. Right: search, account, ideabook, bag.
  Mobile: off-canvas accordion drawer.

  Editable in the theme editor: logo image, navigation menu, ideabook link,
  and which icons to show.
{% endcomment %}

<script src="{{ 'hoc-header.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign menu = linklists[section.settings.menu]
  assign show_account = section.settings.show_account
  assign show_ideabook = section.settings.show_ideabook
-%}

<header
  class="hoc-header{% if template.name == 'index' and section.settings.overlay_on_home %} hoc-header--overlay{% endif %}"
  data-hoc-header
  {% if template.name == 'index' and section.settings.overlay_on_home %}data-hoc-overlay{% endif %}
>
  <div class="hoc-container hoc-header__inner">
    {%- comment %} Mobile: burger {% endcomment -%}
    <button
      type="button"
      class="hoc-iconbtn hoc-burger"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="hoc-menu-drawer"
      data-hoc-menu-open
    >
      {% render 'hoc-icon', name: 'menu' %}
    </button>

    {%- comment %} Logo: theme-editor image, else bundled wordmark, else text {% endcomment -%}
    {%- if section.settings.logo != blank -%}
      <a href="{{ routes.root_url }}" class="hoc-logo">
        <img
          src="{{ section.settings.logo | image_url: width: 480 }}"
          alt="{{ shop.name | escape }}"
          width="{{ section.settings.logo.width }}"
          height="{{ section.settings.logo.height }}"
        >
      </a>
    {%- elsif section.settings.default_logo_filename != blank -%}
      <a href="{{ routes.root_url }}" class="hoc-logo hoc-logo--wordmark">
        <img
          class="hoc-logo__img"
          src="{{ section.settings.default_logo_filename | asset_url }}"
          alt="{{ shop.name | escape }}"
          width="2669"
          height="173"
        >
      </a>
    {%- else -%}
      <a href="{{ routes.root_url }}" class="hoc-logo">{{ shop.name }}</a>
    {%- endif -%}

    {%- comment %} Desktop navigation. Any menu item with sub-items (e.g. Catalog
      → its rooms) renders a hover/focus dropdown; flat items stay plain links. {% endcomment -%}
    {%- if menu != blank -%}
      <nav class="hoc-nav" aria-label="Primary">
        {%- for link in menu.links -%}
          {%- if link.links != blank -%}
            <div class="hoc-nav__item" data-hoc-dropdown>
              <a
                href="{{ link.url }}"
                class="hoc-nav__link hoc-nav__link--parent{% if link.active or link.child_active %} is-active{% endif %}"
                aria-expanded="false"
                aria-controls="hoc-nav-panel-{{ forloop.index }}"
                data-hoc-dropdown-toggle
              >
                {{ link.title }}
                {% render 'hoc-icon', name: 'chevron', class: 'hoc-nav__chev' %}
              </a>
              <div class="hoc-nav__panel" id="hoc-nav-panel-{{ forloop.index }}" data-hoc-dropdown-panel>
                <ul class="hoc-nav__sublist" role="list">
                  {%- for child in link.links -%}
                    <li>
                      <a
                        href="{{ child.url }}"
                        class="hoc-nav__sublink{% if child.active %} is-active{% endif %}"
                      >
                        {{ child.title }}
                      </a>
                    </li>
                  {%- endfor -%}
                </ul>
              </div>
            </div>
          {%- else -%}
            <a
              href="{{ link.url }}"
              class="hoc-nav__link{% if link.active or link.child_active %} is-active{% endif %}"
            >
              {{ link.title }}
            </a>
          {%- endif -%}
        {%- endfor -%}
      </nav>
    {%- endif -%}

    {%- comment %} Trailing icons {% endcomment -%}
    <div class="hoc-header__actions">
      <a href="{{ routes.search_url }}" class="hoc-iconbtn" aria-label="Search" data-hoc-search-open>
        {% render 'hoc-icon', name: 'search' %}
      </a>

      {%- if show_account and shop.customer_accounts_enabled -%}
        <a
          href="{% if customer %}{{ routes.account_url }}{% else %}{{ routes.account_login_url }}{% endif %}"
          class="hoc-iconbtn hoc-iconbtn--desktop"
          aria-label="Account"
        >
          {% render 'hoc-icon', name: 'account' %}
        </a>
      {%- endif -%}

      {%- if show_ideabook -%}
        <a
          href="{{ section.settings.ideabook_link | default: routes.root_url }}"
          class="hoc-iconbtn hoc-iconbtn--desktop"
          aria-label="Ideabook"
        >
          {% render 'hoc-icon', name: 'ideabook' %}
        </a>
      {%- endif -%}

      <a href="{{ routes.cart_url }}" class="hoc-iconbtn" aria-label="Your bag" data-hoc-cart-open>
        {% render 'hoc-icon', name: 'bag' %}
        <span class="hoc-cart-count" data-hoc-cart-count {% if cart.item_count == 0 %}hidden{% endif %}>
          {{ cart.item_count }}
        </span>
      </a>
    </div>
  </div>
</header>

{%- comment %} Mobile off-canvas drawer {% endcomment -%}
<div class="hoc-drawer" id="hoc-menu-drawer" data-hoc-drawer>
  <div class="hoc-drawer__overlay" data-hoc-menu-close></div>
  <div class="hoc-drawer__panel" role="dialog" aria-modal="true" aria-label="Menu">
    <div class="hoc-drawer__head">
      <span class="hoc-logo" style="font-size: var(--t-h3);">{{ shop.name }}</span>
      <button type="button" class="hoc-iconbtn" aria-label="Close menu" data-hoc-menu-close>
        {% render 'hoc-icon', name: 'close' %}
      </button>
    </div>

    {%- if menu != blank -%}
      <nav aria-label="Mobile">
        {%- for link in menu.links -%}
          {%- if link.links != blank -%}
            <details class="hoc-drawer__group">
              <summary class="hoc-drawer__link hoc-drawer__summary">
                {{ link.title }}
                {% render 'hoc-icon', name: 'chevron', class: 'hoc-drawer__chev' %}
              </summary>
              <div class="hoc-drawer__sub">
                <a href="{{ link.url }}" class="hoc-drawer__sublink hoc-drawer__sublink--all">
                  All {{ link.title }}
                </a>
                {%- for child in link.links -%}
                  <a href="{{ child.url }}" class="hoc-drawer__sublink">{{ child.title }}</a>
                {%- endfor -%}
              </div>
            </details>
          {%- else -%}
            <a href="{{ link.url }}" class="hoc-drawer__link">{{ link.title }}</a>
          {%- endif -%}
        {%- endfor -%}
      </nav>
    {%- endif -%}

    <div class="hoc-drawer__utility">
      {%- if show_account and shop.customer_accounts_enabled -%}
        <a
          href="{% if customer %}{{ routes.account_url }}{% else %}{{ routes.account_login_url }}{% endif %}"
          class="hoc-textlink"
        >
          {% render 'hoc-icon', name: 'account' %} {% if customer %}Account{% else %}Sign in{% endif %}
        </a>
      {%- endif -%}
      {%- if show_ideabook -%}
        <a href="{{ section.settings.ideabook_link | default: routes.root_url }}" class="hoc-textlink">
          {% render 'hoc-icon', name: 'ideabook' %} Ideabook
        </a>
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "HoC Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image",
      "info": "Optional. Overrides the bundled wordmark below. If both are empty, the shop name shows as a serif wordmark."
    },
    {
      "type": "text",
      "id": "default_logo_filename",
      "label": "Bundled logo filename (in /assets)",
      "default": "hoc-logo-white.png",
      "info": "White wordmark used when no Logo image is chosen above. Darkens automatically on the solid header."
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation menu",
      "default": "main-menu"
    },
    {
      "type": "checkbox",
      "id": "overlay_on_home",
      "label": "Transparent header over the homepage hero",
      "info": "The header overlays the full-screen hero (light text), turning solid on hover and on scroll.",
      "default": true
    },
    {
      "type": "header",
      "content": "Icons"
    },
    {
      "type": "checkbox",
      "id": "show_account",
      "label": "Show account icon",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_ideabook",
      "label": "Show ideabook icon",
      "default": true
    },
    {
      "type": "url",
      "id": "ideabook_link",
      "label": "Ideabook link",
      "info": "Where the bookmark icon goes (e.g. a page). Leave empty for now."
    }
  ]
}
{% endschema %}
