{% comment %}
  House of Clarence — Product page (prd.md §8.3)
  Gallery (4:5 primary + thumbnails), specimen caption, plain price (+ex-VAT),
  variant selection, Add to bag, Save to ideabook, the Specimen block spec-sheet,
  editorial description, delivery note, and a "Pairs well" row.
  No urgency, no countdowns, no "X people viewing".
{% endcomment %}

<script src="{{ 'hoc-product.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign current = product.selected_or_first_available_variant
  assign media = product.media
-%}

<section class="hoc-pdp hoc-container">
  {%- comment %} Breadcrumbs {% endcomment -%}
  <nav class="hoc-breadcrumb hoc-specimen" aria-label="Breadcrumb">
    <a href="{{ routes.root_url }}">Home</a>
    <span class="hoc-breadcrumb__sep">/</span>
    {%- if collection.url -%}
      <a href="{{ collection.url }}">{{ collection.title }}</a>
      <span class="hoc-breadcrumb__sep">/</span>
    {%- elsif product.type != blank -%}
      <a href="{{ routes.collections_url }}">{{ product.type }}</a>
      <span class="hoc-breadcrumb__sep">/</span>
    {%- endif -%}
    <span aria-current="page">{{ product.title }}</span>
  </nav>

  <div class="hoc-pdp__grid">
    {%- comment %} ============ Gallery ============ {% endcomment -%}
    <div class="hoc-pdp__gallery" data-hoc-gallery>
      <div class="hoc-pdp__stage">
        {%- if media.size > 0 -%}
          {%- assign main_media = current.featured_media | default: media[0] -%}
          <img
            data-hoc-stage-img
            src="{{ main_media | image_url: width: 1200 }}"
            srcset="{{ main_media | image_url: width: 600 }} 600w, {{ main_media | image_url: width: 1000 }} 1000w, {{ main_media | image_url: width: 1400 }} 1400w"
            sizes="(min-width: 768px) 55vw, 100vw"
            alt="{{ main_media.alt | default: product.title | escape }}"
            width="{{ main_media.width }}"
            height="{{ main_media.height }}"
            fetchpriority="high"
          >
        {%- else -%}
          {{ 'product-1' | placeholder_svg_tag: 'placeholder' }}
        {%- endif -%}
      </div>

      {%- if media.size > 1 -%}
        <div class="hoc-pdp__thumbs" role="list">
          {%- for m in media -%}
            <button
              type="button"
              class="hoc-pdp__thumb{% if forloop.first %} is-active{% endif %}"
              role="listitem"
              aria-label="View image {{ forloop.index }}"
              data-hoc-thumb
              data-full="{{ m | image_url: width: 1400 }}"
              data-srcset="{{ m | image_url: width: 600 }} 600w, {{ m | image_url: width: 1000 }} 1000w, {{ m | image_url: width: 1400 }} 1400w"
              data-alt="{{ m.alt | default: product.title | escape }}"
            >
              <img src="{{ m | image_url: width: 240 }}" alt="" loading="lazy" width="240" height="240">
            </button>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    {%- comment %} ============ Info column ============ {% endcomment -%}
    <div class="hoc-pdp__info">
      <span class="hoc-eyebrow hoc-pdp__eyebrow">{% render 'hoc-specimen-meta', product: product %}</span>
      <h1 class="hoc-h1 hoc-pdp__title">{{ product.title }}</h1>

      <div class="hoc-pdp__price hoc-body-l" data-hoc-price>
        {% render 'hoc-price', price: current.price, compare_at: current.compare_at_price, show_exvat: section.settings.show_exvat %}
      </div>

      {%- comment %} ---- Add to bag form ---- {% endcomment -%}
      <form
        action="{{ routes.cart_add_url }}"
        method="post"
        enctype="multipart/form-data"
        class="hoc-pdp__form"
        data-hoc-product-form
      >
        {%- comment %} Variant options {% endcomment -%}
        {%- unless product.has_only_default_variant -%}
          {%- for option in product.options_with_values -%}
            <fieldset class="hoc-variant" data-hoc-option-index="{{ forloop.index0 }}">
              <legend class="hoc-eyebrow hoc-variant__label">{{ option.name }}</legend>
              <div class="hoc-variant__options">
                {%- for value in option.values -%}
                  {%- assign opt_id = section.id | append: '-' | append: option.position | append: '-' | append: forloop.index0 -%}
                  <input
                    type="radio"
                    class="hoc-visually-hidden"
                    id="{{ opt_id }}"
                    name="option-{{ option.position }}"
                    value="{{ value | escape }}"
                    data-hoc-option-value
                    {% if option.selected_value == value %}checked{% endif %}
                  >
                  <label for="{{ opt_id }}" class="hoc-variant__chip">{{ value }}</label>
                {%- endfor -%}
              </div>
            </fieldset>
          {%- endfor -%}
        {%- endunless -%}

        <input type="hidden" name="id" value="{{ current.id }}" data-hoc-variant-id>

        <div class="hoc-pdp__cta">
          <button
            type="submit"
            class="hoc-btn hoc-btn--primary hoc-btn--full"
            data-hoc-add
            {% unless current.available %}disabled{% endunless %}
          >
            <span data-hoc-add-text>{% if current.available %}Add to bag{% else %}Sold out{% endif %}</span>
          </button>
          <button type="button" class="hoc-btn hoc-btn--secondary hoc-btn--full" data-hoc-save data-product-id="{{ product.id }}">
            {% render 'hoc-icon', name: 'ideabook' %} Save to ideabook
          </button>
        </div>
      </form>

      {%- comment %} Variant data for the JS picker {% endcomment -%}
      <script type="application/json" data-hoc-variant-json>
        {{ product.variants | json }}
      </script>

      {%- comment %} Delivery teaser {% endcomment -%}
      <p class="hoc-pdp__delivery hoc-body">
        {% render 'hoc-icon', name: 'delivery' %}
        {{ section.settings.delivery_note }}
      </p>
    </div>
  </div>

  {%- comment %} ============ Details: description + specimen block ============ {% endcomment -%}
  <div class="hoc-pdp__details">
    <div class="hoc-pdp__desc">
      {%- if section.settings.details_heading != blank -%}
        <h2 class="hoc-h2">{{ section.settings.details_heading }}</h2>
      {%- endif -%}
      {%- if product.description != blank -%}
        <div class="hoc-body-l hoc-rte">{{ product.description }}</div>
      {%- endif -%}
    </div>
    <div class="hoc-pdp__spec">
      {% render 'hoc-specimen-block', product: product, variant: current, lead_time_default: section.settings.delivery_note %}
    </div>
  </div>
</section>

{%- comment %} ============ Pairs well ============ {% endcomment -%}
{%- liquid
  assign related = product.collections.first.products
  if related == blank or related.size <= 1
    assign related = collections['all'].products
  endif
-%}
{%- if related.size > 1 -%}
  <section class="hoc-section hoc-surface-paper hoc-pairs">
    <div class="hoc-container">
      <div class="hoc-section-head">
        <h2 class="hoc-h2">Pairs well</h2>
        <a href="{{ routes.collections_url }}" class="hoc-textlink">View all {% render 'hoc-icon', name: 'arrow' %}</a>
      </div>
      <div class="hoc-grid hoc-grid--3">
        {%- assign shown = 0 -%}
        {%- for p in related -%}
          {%- unless p.handle contains 'example-product' or p.handle contains 'asset-pack' -%}
            {%- if p.id != product.id and shown < 3 -%}
              {% render 'hoc-product-card', product: p, layout: 'pairs', show_save: false %}
              {%- assign shown = shown | plus: 1 -%}
            {%- endif -%}
          {%- endunless -%}
        {%- endfor -%}
      </div>
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "Product",
  "settings": [
    { "type": "checkbox", "id": "show_exvat", "label": "Show ex-VAT price", "default": true },
    { "type": "text", "id": "details_heading", "label": "Details heading", "default": "Honest material, architectural precision" },
    { "type": "textarea", "id": "delivery_note", "label": "Delivery / lead-time note", "default": "Made to order. Estimated lead time 6–8 weeks." }
  ]
}
{% endschema %}
