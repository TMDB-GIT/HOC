{% comment %}
  House of Clarence — Rich text
  A calm, centred editorial reading column (~720px). For story/manifesto copy.
{% endcomment %}

<section class="hoc-section {% if section.settings.surface == 'paper' %}hoc-surface-paper{% elsif section.settings.surface == 'sage' %}hoc-surface-sage{% endif %}">
  <div class="hoc-container">
    <div class="hoc-prose" style="margin-inline:auto;">
      {%- if section.settings.eyebrow != blank -%}
        <span class="hoc-eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="hoc-h2" style="margin:var(--s-2) 0 var(--s-3);">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.text != blank -%}
        <div class="hoc-rte">{{ section.settings.text }}</div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "HoC Rich text",
  "settings": [
    {
      "type": "select",
      "id": "surface",
      "label": "Background",
      "options": [
        { "value": "canvas", "label": "Canvas" },
        { "value": "paper", "label": "Paper" },
        { "value": "sage", "label": "Sage" }
      ],
      "default": "canvas"
    },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Tell the House of Clarence story here.</p>" }
  ],
  "presets": [{ "name": "HoC Rich text" }]
}
{% endschema %}
