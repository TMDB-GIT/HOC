{% comment %}
  House of Clarence — Collection / room tiles (prd.md §8.1)
  Editorial tiles linking to collections, with a mono eyebrow label over big
  imagery and a gentle vertical stagger. Each tile is a block.
{% endcomment %}

<section class="hoc-section hoc-collection-tiles">
  <div class="hoc-container">
    {%- if section.settings.heading != blank or section.settings.link_label != blank -%}
      <div class="hoc-section-head">
        <h2 class="hoc-h2">{{ section.settings.heading }}</h2>
        {%- if section.settings.link_label != blank -%}
          <a href="{{ section.settings.link_url | default: routes.collections_url }}" class="hoc-textlink">
            {{ section.settings.link_label }} {% render 'hoc-icon', name: 'arrow' %}
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="hoc-tiles hoc-tiles--4">
      {%- for block in section.blocks -%}
        {%- liquid
          assign collection = collections[block.settings.collection]
          assign tile_image = block.settings.image
          if tile_image == blank and collection != blank
            assign tile_image = collection.featured_image
          endif
          assign tile_label = block.settings.label
          if tile_label == blank and collection != blank
            assign tile_label = collection.title
          endif
          assign tile_url = block.settings.link
          if tile_url == blank and collection != blank
            assign tile_url = collection.url
          endif
        -%}
        <a href="{{ tile_url | default: routes.collections_url }}" class="hoc-tile" {{ block.shopify_attributes }}>
          {%- if tile_image != blank -%}
            <img
              src="{{ tile_image | image_url: width: 700 }}"
              srcset="{{ tile_image | image_url: width: 400 }} 400w, {{ tile_image | image_url: width: 700 }} 700w, {{ tile_image | image_url: width: 1000 }} 1000w"
              sizes="(min-width: 1024px) 22vw, (min-width: 600px) 45vw, 90vw"
              alt="{{ tile_image.alt | default: tile_label | escape }}"
              loading="lazy"
              width="{{ tile_image.width }}"
              height="{{ tile_image.height }}"
            >
          {%- elsif block.settings.default_image_filename != blank -%}
            {%- comment %} Fallback to an image bundled in /assets (placeholder until client photography). {% endcomment -%}
            <img
              src="{{ block.settings.default_image_filename | asset_url }}"
              alt="{{ tile_label | escape }}"
              loading="lazy"
              width="1200"
              height="1200"
            >
          {%- else -%}
            {{ 'collection-1' | placeholder_svg_tag: 'placeholder' }}
          {%- endif -%}
          <span class="hoc-tile__label">
            <span class="hoc-eyebrow">{{ tile_label }}</span>
          </span>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Collection tiles",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Shop by room" },
    { "type": "text", "id": "link_label", "label": "Link label", "default": "View all" },
    { "type": "url", "id": "link_url", "label": "Link URL" }
  ],
  "blocks": [
    {
      "type": "tile",
      "name": "Room tile",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Collection" },
        { "type": "image_picker", "id": "image", "label": "Image override", "info": "Optional. Defaults to the collection image." },
        { "type": "text", "id": "default_image_filename", "label": "Bundled image filename (in /assets)", "info": "Used when no image is chosen and the collection has none." },
        { "type": "text", "id": "label", "label": "Label override", "info": "Optional. Defaults to the collection title." },
        { "type": "url", "id": "link", "label": "Link override" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection tiles",
      "blocks": [
        { "type": "tile" },
        { "type": "tile" },
        { "type": "tile" },
        { "type": "tile" }
      ]
    }
  ]
}
{% endschema %}
