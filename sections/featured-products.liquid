{% comment %}
  House of Clarence — Featured products (prd.md §8.1)
  A curated row of specimen cards from a chosen collection.
{% endcomment %}

{%- liquid
  assign collection = collections[section.settings.collection]
  # Fall back to "all products" so the row is populated before collections exist.
  if collection == blank or collection.products.size == 0
    assign collection = collections['all']
  endif
  assign limit = section.settings.products_to_show
-%}

<section class="hoc-section hoc-featured-products">
  <div class="hoc-container">
    {%- if section.settings.heading != blank -%}
      <div class="hoc-section-head">
        <h2 class="hoc-h2">{{ section.settings.heading }}</h2>
        {%- if section.settings.link_label != blank and collection != blank -%}
          <a href="{{ collection.url }}" class="hoc-textlink">
            {{ section.settings.link_label }} {% render 'hoc-icon', name: 'arrow' %}
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="hoc-grid hoc-grid--4">
      {%- assign shown = 0 -%}
      {%- if collection != blank and collection.products.size > 0 -%}
        {%- for product in collection.products -%}
          {%- comment %} Skip Dawn's sample "example" products {% endcomment -%}
          {%- unless product.handle contains 'example-product' or product.handle contains 'asset-pack' -%}
            {%- if shown < limit -%}
              {% render 'hoc-product-card', product: product, layout: 'featured' %}
              {%- assign shown = shown | plus: 1 -%}
            {%- endif -%}
          {%- endunless -%}
        {%- endfor -%}
      {%- endif -%}
      {%- if shown == 0 -%}
        {%- comment %} Placeholder cards so the section is visible before a collection is chosen {% endcomment -%}
        {%- for i in (1..4) -%}
          <div class="hoc-card">
            <div class="hoc-card__media">{{ 'product-1' | placeholder_svg_tag: 'placeholder' }}</div>
            <h3 class="hoc-card__title">Specimen title</h3>
            <span class="hoc-specimen hoc-card__caption">MATERIAL · FINISH <span class="hoc-specimen__sep">/</span> <span class="hoc-specimen__price">£0</span></span>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured products",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Featured curations" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "products_to_show", "label": "Products to show", "min": 2, "max": 8, "step": 1, "default": 4 },
    { "type": "text", "id": "link_label", "label": "Link label", "default": "View all" }
  ],
  "presets": [{ "name": "Featured products" }]
}
{% endschema %}
